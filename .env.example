# Copie para .env na raiz do projeto: copy .env.example .env  (Windows: copie manualmente)
# Preencha no servidor (VPS) com valores reais.
#
# DESENVOLVIMENTO (PC): pode não usar .env — DEBUG fica True por padrão.
#
# --- PRODUÇÃO (VPS) com domínio + IP (ex.: Controle S M Decor) ---
# Ajuste o domínio/IP se for diferente. Depois de HTTPS (Certbot), use só https nas origens CORS/CSRF.
#
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=<gere: python -c "import secrets; print(secrets.token_urlsafe(50))">
# DJANGO_ALLOWED_HOSTS=santosmarinoto.com,www.santosmarinoto.com,129.121.53.239
# DJANGO_CORS_ALLOWED_ORIGINS=https://santosmarinoto.com,https://www.santosmarinoto.com,http://santosmarinoto.com,http://www.santosmarinoto.com,http://129.121.53.239
# DJANGO_CSRF_TRUSTED_ORIGINS=https://santosmarinoto.com,https://www.santosmarinoto.com,http://santosmarinoto.com,http://www.santosmarinoto.com,http://129.121.53.239
# DJANGO_USE_X_FORWARDED_HOST=True
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=False
#
# Só HTTP por IP (sem SSL ainda): DJANGO_SECURE_SSL_REDIRECT=False e origens http acima.
#
# --- Genérico (outro domínio) ---
# DJANGO_ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
# DJANGO_CORS_ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
# DJANGO_CSRF_TRUSTED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CORS_ALLOWED_ORIGINS=
# DJANGO_CSRF_TRUSTED_ORIGINS=
