# Copie para .env na raiz do projeto: copy .env.example .env  (Windows: copie manualmente)
# Preencha no servidor (VPS) com valores reais.
#
# DESENVOLVIMENTO (PC): pode não usar .env — DEBUG fica True por padrão.
#
# PRODUÇÃO (VPS) — defina todas estas variáveis:
#
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=<gere: python -c "import secrets; print(secrets.token_urlsafe(50))">
# DJANGO_ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
# DJANGO_CORS_ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
# DJANGO_CSRF_TRUSTED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
# DJANGO_USE_X_FORWARDED_HOST=True
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=False
#
# Se testar só por IP: inclua o IP em DJANGO_ALLOWED_HOSTS (ex.: 129.x.x.x).

DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CORS_ALLOWED_ORIGINS=
# DJANGO_CSRF_TRUSTED_ORIGINS=
